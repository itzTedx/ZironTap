{
	"name": "@ziron/db",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"build": "tsc",
		"db:push": "pnpm with-env drizzle-kit push",
		"db:generate": "pnpm with-env drizzle-kit generate",
		"db:migrate": "pnpm with-env drizzle-kit migrate",
		"db:migrate:run": "tsx src/migrate.ts",
		"db:studio": "pnpm with-env drizzle-kit studio",
		"with-env": "pnpm exec dotenv -e ../../apps/portal/.env --"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1",
		"pg": "^8.20.0",
		"zod": "catalog:",
		"dotenv-cli": "catalog:"
	},
	"devDependencies": {
		"@ziron/typescript-config": "workspace:*",
		"@ziron/env": "workspace:*",
		"@types/node": "catalog:",
		"@types/pg": "^8.18.0",
		"drizzle-kit": "^0.31.9",
		"tsx": "^4.19.2",
		"typescript": "catalog:"
	},
	"exports": {
		".": "./src/index.ts",
		"./schema": "./src/schema/index.ts",
		"./migrate": "./src/migrate.ts"
	}
}
