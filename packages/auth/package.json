{
	"name": "@ziron/auth",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "tsc",
		"lint": "biome check .",
		"format": "biome format --write .",
		"generate": "pnpm with-env pnpx @better-auth/cli generate --output ../db/src/schema/auth.ts --config ./src/index.ts",
		"auth:generate": "pnpm run generate",
		"with-env": "pnpm exec dotenv -e ../../apps/portal/.env --",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@better-auth/api-key": "catalog:",
		"@better-auth/drizzle-adapter": "catalog:",
		"@better-auth/passkey": "catalog:",
		"@ziron/cache": "workspace:*",
		"@ziron/db": "workspace:*",
		"@ziron/env": "workspace:*",
		"better-auth": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@ziron/typescript-config": "workspace:*",
		"dotenv-cli": "catalog:",
		"typescript": "catalog:"
	},
	"exports": {
		".": "./src/index.ts"
	}
}
