{
	"$schema": "https://ui.shadcn.com/schema.json",
	"style": "base-nova",
	"rsc": true,
	"tsx": true,
	"tailwind": {
		"config": "",
		"css": "src/styles/globals.css",
		"baseColor": "neutral",
		"cssVariables": true
	},
	"iconLibrary": "phosphor",
	"rtl": false,
	"menuColor": "default",
