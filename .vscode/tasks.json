{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "pnpm build",
			"group": "build",
			"presentation": { "reveal": "always" }
		},
		{
			"label": "dev",
			"type": "shell",
			"command": "pnpm dev",
			"group": "none",
			"isBackground": true,
			"presentation": { "reveal": "always" }
		},
		{
			"label": "lint",
			"type": "shell",
			"command": "pnpm lint",
			"group": "test",
			"presentation": { "reveal": "always" }
		},
		{
			"label": "typecheck",
			"type": "shell",
			"command": "pnpm typecheck",
			"group": "test",
			"presentation": { "reveal": "always" }
		}
	]
}
